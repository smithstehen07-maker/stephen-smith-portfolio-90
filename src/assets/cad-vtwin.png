r\":\"#3A1717\",\"colors\":[\"#EDE9D5\",\"#502222\",\"#3A1717\",\"#EDE9D5\"],\"colorTokens\":{\"primary\":\"oklch(85% 0.04 80)\",\"primaryForeground\":\"oklch(20% 0.06 20)\",\"background\":\"oklch(22% 0.06 20)\",\"foreground\":\"oklch(92% 0.03 80)\",\"secondary\":\"oklch(28% 0.06 20)\",\"secondaryForeground\":\"oklch(90% 0.03 80)\",\"accent\":\"oklch(30% 0.07 20)\",\"accentForeground\":\"oklch(92% 0.03 80)\",\"muted\":\"oklch(26% 0.05 20)\",\"mutedForeground\":\"oklch(65% 0.03 20)\",\"card\":\"oklch(25% 0.06 20)\",\"cardForeground\":\"oklch(92% 0.03 80)\",\"popover\":\"oklch(25% 0.06 20)\",\"popoverForeground\":\"oklch(92% 0.03 80)\",\"destructive\":\"oklch(62.8% 0.208 22.7)\",\"destructiveForeground\":\"oklch(100% 0 0)\",\"border\":\"oklch(32% 0.05 20)\",\"input\":\"oklch(32% 0.05 20)\",\"ring\":\"oklch(85% 0.04 80)\"},\"font\":{\"heading\":{\"family\":\"Cabinet Grotesk\",\"url\":\"https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800\u0026display=swap\",\"weight\":800},\"body\":{\"family\":\"IBM Plex Sans\",\"url\":\"https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700\u0026display=swap\"}},\"project_id\":\"dffa3515-3b90-4d8e-b773-e76b978f047a\"}]},{\"slug\":\"continuum-daily-habit-tracker-template\",\"id\":\"continuum-daily-habit-tracker-template\",\"title\":\"Continuum\",\"pageTitle\":\"Continuum - Daily Habit Tracker Template\",\"category\":\"Apps\",\"project_id\":\"4ce33a84-200a-449a-a4e7-de34962210f0\",\"url\":\"https://continuum-daily.lovable.app\",\"subtitle\":\"A calm, distraction-free habit tracker with streak counters, calendar heatmaps, and motivational insights\",\"description\":\"Build and maintain daily habits with streak tracking, calendar heatmaps, and progress insights. A calm, focused, ad-free habit tracker you can deploy in minutes.\",\"metaTitle\":\"Habit Tracker Template | Daily Streaks \u0026 Progress | Lovable\",\"metaDescription\":\"Build and track daily habits with streak tracking, calendar heatmaps, and progress insights. A calm, ad-free habit tracker template you can deploy in minutes.\",\"subcategory\":\"saas\",\"platform\":\"web\",\"screenshot\":\"https://storage.googleapis.com/lovable-assets/templates/continuum.jpg\",\"thumbnail\":\"https://storage.googleapis.com/lovable-assets/templates/continuum.jpg\",\"previewScreenshot\":\"https://storage.googleapis.com/lovable-assets/templates/continuum.jpg\",\"author\":{\"username\":\"Lovable\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"shownOn\":[\"dashboard-templates\",\"homepage\",\"templates\"],\"date\":\"2026-04-09T00:00:00.000000\",\"lastModified\":\"2026-04-09T00:00:00.000000\",\"highlights\":[{\"icon\":\"local_fire_department\",\"title\":\"Streak tracking with milestones\",\"description\":\"Current and longest streak counters update automatically. Milestone messages celebrate achievements at 7, 14, 30, 100, and 365 days.\"},{\"icon\":\"calendar_month\",\"title\":\"Calendar heatmap visualization\",\"description\":\"A 30-day heatmap on each habit card shows your recent consistency at a glance. Completed days are highlighted in the habit's color.\"},{\"icon\":\"event_repeat\",\"title\":\"Flexible scheduling (daily, weekly, specific days)\",\"description\":\"Set habits as daily, specific weekdays, or a target number of times per week. The streak calculator accounts for non-scheduled days.\"},{\"icon\":\"drag_indicator\",\"title\":\"Drag-and-drop habit reordering\",\"description\":\"Reorder habits by dragging them into your preferred order. Position changes persist to the database automatically.\"},{\"icon\":\"cloud_sync\",\"title\":\"Cloud sync with authentication\",\"description\":\"Email/password and Google sign-in keep your data synced across devices. All habits and logs are stored securely in the cloud.\"},{\"icon\":\"insights\",\"title\":\"Progress insights and analytics\",\"description\":\"A dedicated insights page shows completion rates, streak data, and progress visualizations across all your habits.\"}],\"features\":[{\"title\":\"Habit creation with custom colors\",\"description\":\"Create habits with a name, description, and color from a curated palette. Each habit card is visually distinct so your dashboard is easy to scan.\"},{\"title\":\"Streak tracking with milestones\",\"description\":\"Current and longest streak counters update automatically. Milestone messages celebrate achievements at 7, 14, 21, 30, 50, 100, 200, and 365 days.\"},{\"title\":\"Calendar heatmap\",\"description\":\"A 30-day heatmap on each habit card shows your recent consistency at a glance. Completed days are highlighted in the habit's color.\"},{\"title\":\"Flexible frequency scheduling\",\"description\":\"Set habits as daily, specific weekdays (e.g. Mon/Wed/Fri), or a target number of times per week. The streak calculator accounts for non-scheduled days.\"},{\"title\":\"Drag-and-drop reordering\",\"description\":\"Reorder habits by dragging them into your preferred order. Position changes persist to the database automatically.\"},{\"title\":\"Insights and analytics\",\"description\":\"A dedicated insights page shows completion rates, streak data, and progress visualizations across all your habits.\"},{\"title\":\"Cloud sync with authentication\",\"description\":\"Email/password and Google sign-in keep your data synced across devices. All habits and logs are stored securely in the cloud.\"},{\"title\":\"Onboarding flow\",\"description\":\"New users are guided through creating their first habits with a clean, step-by-step onboarding experience.\"},{\"title\":\"Settings and data management\",\"description\":\"Manage your account, clear all data, or sign out from the settings page.\"},{\"title\":\"Responsive design\",\"description\":\"Works on desktop, tablet, and mobile with a bottom navigation bar optimized for mobile use.\"},{\"title\":\"Dark mode support\",\"description\":\"Full dark mode with carefully tuned colors that match the app's calm, focused aesthetic.\"},{\"title\":\"Reminder times\",\"description\":\"Set optional reminder times for each habit to help you stay on track throughout the day.\"}],\"content\":\"$4f\",\"relativePath\":\"continuum-daily-habit-tracker-template.md\"},{\"slug\":\"lovable-slides\",\"id\":\"f003850e-32d2-409c-8cfc-5fc9e5ea172f\",\"title\":\"Lovable slides\",\"pageTitle\":\"Interactive Presentation Builder Template\",\"category\":\"Apps\",\"project_id\":\"f003850e-32d2-409c-8cfc-5fc9e5ea172f\",\"url\":\"https://lov-slides.lovable.app\",\"subtitle\":\"Code-powered presentation builder\",\"description\":\"Create professional presentations with unlimited possibilities. Add interactive charts, real-time calculations, custom components, and anything you can build with React. Perfect for demos, education, and business pitches.\",\"metaTitle\":\"Interactive Presentation Template | Lovable Slides | Lovable\",\"metaDescription\":\"Build interactive slide decks with live data, custom components, and dynamic interactions. A modern alternative to static presentations - deploy in minutes.\",\"subcategory\":\"saas\",\"platform\":\"Web\",\"screenshot\":\"https://assets.lovable.dev/templates/lovable-slides-final.webp\",\"thumbnail\":\"https://assets.lovable.dev/templates/lovable-slides-final.webp\",\"previewScreenshot\":\"https://assets.lovable.dev/templates/lovable-slides-final.webp\",\"author\":{\"username\":\"Aleksander Heino\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"shownOn\":[\"dashboard-templates\",\"homepage\",\"templates\"],\"date\":\"2026-12-31T23:59:59.000Z\",\"lastModified\":\"2026-02-12T18:00:00.000Z\",\"highlights\":[{\"icon\":\"code\",\"title\":\"Code-Powered Interactivity\",\"description\":\"Build anything you can imagine with React—interactive charts, simulations, calculators, and custom components that respond to user input\"},{\"icon\":\"sync\",\"title\":\"Live Data and Real-Time Updates\",\"description\":\"Connect to APIs, display dynamic calculations, and show real-time metrics that update as users interact with your slides\"},{\"icon\":\"widgets\",\"title\":\"Beyond Static Slides\",\"description\":\"Embed 3D graphics, interactive visualizations, forms, animations, or any web component directly in your presentation\"},{\"icon\":\"palette\",\"title\":\"Full Customization Control\",\"description\":\"Complete design freedom with React components, CSS styling, and modern web technologies—no template constraints\"},{\"icon\":\"presentation\",\"title\":\"Professional Presentation Mode\",\"description\":\"Fullscreen mode with keyboard navigation, thumbnail sidebar, zoom controls, and smooth transitions for polished delivery\"}],\"features\":[{\"title\":\"React Component Architecture\",\"description\":\"Build slides with React components—create interactive charts, data visualizations, forms, animations, or any custom UI you need for your presentation.\"},{\"title\":\"Real-Time Interactivity\",\"description\":\"Add live calculations, adjustable parameters, and dynamic content that updates as users interact. Perfect for demos, simulations, and educational content.\"},{\"title\":\"Embed Any Web Technology\",\"description\":\"Use 3D libraries, data visualization frameworks, animation libraries, or any npm package. Build presentations as powerful as web applications.\"},{\"title\":\"Fixed Resolution Scaling System\",\"description\":\"All slides render at 1920x1080 and scale perfectly to any screen size using transform scaling, ensuring consistent appearance across all devices and projectors.\"},{\"title\":\"Professional Presentation Controls\",\"description\":\"Fullscreen mode with keyboard navigation (arrow keys), thumbnail sidebar for quick navigation, zoom controls, and progress indicators for smooth delivery.\"},{\"title\":\"Flexible Layout System\",\"description\":\"Responsive grid layouts that adapt from mobile to desktop. Use Tailwind CSS or custom styles to create exactly the layout you need.\"},{\"title\":\"State Management Built In\",\"description\":\"Use React hooks and state to create interactive slides where user actions affect what's displayed. Build multi-step demonstrations and guided experiences.\"},{\"title\":\"Code-First Workflow\",\"description\":\"Edit slides as React components with full TypeScript support. Version control your presentations with git and collaborate like you would on any code project.\"}],\"content\":\"$50\",\"relativePath\":\"lovable-slides.md\"},{\"slug\":\"prompt-frame-portfolio\",\"id\":\"b6c40bed-7568-4fcf-af4c-3a7d2db23b6d\",\"title\":\"Prompt Frame Creative Portfolio\",\"pageTitle\":\"Prompt Frame Creative Portfolio\",\"category\":\"Websites\",\"project_id\":\"b6c40bed-7568-4fcf-af4c-3a7d2db23b6d\",\"url\":\"https://lovable-prompt-frame.lovable.app\",\"subtitle\":\"Launch a premium portfolio that attracts high-value clients without hiring a designer. Showcase your best work with polished layouts that justify premium rates.\",\"tagline\":\"Dark-first premium aesthetic\",\"description\":\"Launch a premium portfolio that attracts high-value clients without hiring a designer. Showcase your best work with polished layouts that justify premium rates.\",\"metaTitle\":\"Portfolio Template for Creatives | Lovable\",\"metaDescription\":\"Build a professional portfolio that justifies premium rates. Showcase client work with polished layouts, dark mode, and mobile-ready design—no coding required.\",\"subcategory\":\"portfolio\",\"platform\":\"web\",\"screenshot\":\"https://assets.lovable.dev/templates/prompt-frame-portfolio-screenshot.webp\",\"thumbnail\":\"https://assets.lovable.dev/templates/prompt-frame-portfolio-screenshot.webp\",\"previewScreenshot\":\"https://assets.lovable.dev/templates/previews/prompt-frame-portfolio-preview.webp\",\"colorPalette\":[\"#000000\",\"#CBFF00\",\"#1A1A1A\",\"#FFFFFF\",\"#2C2C2C\"],\"author\":{\"username\":\"Lovable\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"featured\":true,\"shownOn\":[\"homepage\",\"dashboard-templates\",\"templates\"],\"date\":\"2025-12-12T17:15:46.597Z\",\"lastModified\":\"2025-12-12T17:15:46.597Z\",\"highlights\":[{\"icon\":\"ai\",\"title\":\"Interactive Portfolio Experience\",\"description\":\"Mouse-tracking parallax and hover-reveal images create memorable first impressions for creative work.\"},{\"icon\":\"color_palette\",\"title\":\"Dark-First Premium Aesthetic\",\"description\":\"Pure black backgrounds with lime accents deliver sophisticated visual impact for portfolio showcases.\"},{\"icon\":\"devices\",\"title\":\"Mobile-Optimized Responsive Design\",\"description\":\"Pixel-perfect layouts from mobile to desktop optimized for viewing creative projects everywhere.\"},{\"icon\":\"half_moon\",\"title\":\"Complete Theme System\",\"description\":\"Instant light/dark mode switching with sophisticated color palettes maintains brand consistency throughout.\"}],\"features\":[{\"title\":\"Mouse-Tracking Parallax Hero\",\"description\":\"Interactive hero grid with smooth parallax effects that respond to mouse movement, creating an immersive first impression for visitors.\"},{\"title\":\"Project Reveal Hover Images\",\"description\":\"Floating project images appear elegantly when hovering over list items, providing visual previews without cluttering the interface.\"},{\"title\":\"Auto-Reveal Navigation Header\",\"description\":\"Smart header that appears when users move their mouse to the top of the screen, maximizing content visibility.\"},{\"title\":\"Premium Typography System\",\"description\":\"Professional Syne and Inter font pairing with fluid type scales from 48px to 128px for exceptional readability across devices.\"},{\"title\":\"Complete Dark/Light Theme System\",\"description\":\"Sophisticated theme switching with pure black backgrounds, lime accents, and smooth transitions between light and dark modes using CSS variables.\"},{\"title\":\"Mobile-First Responsive Design\",\"description\":\"Adapts seamlessly from mobile to desktop with staggered animations, full-screen mobile navigation, and optimized touch interactions for portfolios.\"},{\"title\":\"Professional Project Showcase\",\"description\":\"Structured project data with categories, tags, years, and clients, organized for elegant presentation and future filtering capabilities.\"},{\"title\":\"Modern React Development Stack\",\"description\":\"Built with Vite, React 18, TypeScript, and Tailwind CSS for fast performance, type safety, and maintainable code.\"},{\"title\":\"Zero-Radius Minimalist Design\",\"description\":\"Sharp-cornered aesthetic with strategic spacing, clean grid layouts, and sophisticated hover states that convey modern professionalism.\"}],\"content\":\"$51\",\"relativePath\":\"prompt-frame-portfolio.md\"},{\"slug\":\"ecommerce-store-1\",\"id\":\"ecommerce-store-1\",\"title\":\"Ecommerce Store Website Template\",\"pageTitle\":\"Ecommerce Store Website Template\",\"category\":\"Websites\",\"project_id\":\"a8e59680-e4fc-4735-a797-36af2f7e2875\",\"url\":\"https://linea-jewelry.lovable.app\",\"subtitle\":\"Launch a luxury jewelry store with editorial-grade product showcases and complete checkout flow. Professional design, mobile-optimized browsing, and premium brand presentation—go live in hours, not weeks.\",\"tagline\":\"Premium design for webstore\",\"description\":\"This template gives you a complete jewelry e-commerce store that looks professional and you don't need design skills to make it work.\",\"metaTitle\":\"Ecommerce Store Website Template | Online Shop Builder | Lovable\",\"metaDescription\":\"Launch a modern online store with this free ecommerce template. Clean product pages, cart functionality, and responsive design - ready to customise.\",\"subcategory\":\"ecommerce\",\"platform\":\"Web\",\"screenshot\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"thumbnail\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"previewScreenshot\":\"https://assets.lovable.dev/templates/ecommerce-store-1-screenshot.webp\",\"author\":{\"username\":\"Rickard Liljeros\",\"avatar\":\"https://lovable.dev/img/logo/lovable-icon-bg-light.png\"},\"shownOn\":[\"dashboard-templates\",\"homepage\",\"templates\"],\"is_partner_template\":true,\"date\":\"2025-12-01T10:00:00.000Z\",\"highlights\":[{\"icon\":\"cart\",\"title\":\"Launch-Ready Ecommerce Store\",\"description\":\"Complete e-commerce frontend with product galleries, checkout flow, and editorial storytelling for luxury brands\"},{\"icon\":\"image_stack\",\"title\":\"Editorial-Grade Product Showcases\",\"description\":\"Professional image galleries with zoom capabilities designed specifically for jewelry and luxury product photography\"},{\"icon\":\"color_palette\",\"title\":\"Premium Design System Included\",\"description\":\"40+ UI components with custom typography and color theming for sophisticated brand presentation\"},{\"icon\":\"phone_iphone\",\"title\":\"Mobile-First Luxury Experience\",\"description\":\"Responsive layouts optimized for viewing fine jewelry on any device with professional polish\"},{\"icon\":\"search\",\"title\":\"SEO-Optimized for Discovery\",\"description\":\"Pre-configured meta tags and structured data to help customers find your jewelry collection\"}],\"features\":[{\"title\":\"Complete Page Architecture\",\"description\":\"Homepage, category pages, product details, checkout, about sections, sustainability story, size guide, and customer care all included\"},{\"title\":\"Product Image Galleries\",\"description\":\"Interactive image galleries with zoom functionality showcase jewelry details, perfect for displaying craftsmanship and materials at scale\"},{\"title\":\"Flexible Content Sections\",\"description\":\"Hero banners, 50/50 splits, asymmetric layouts, and carousels enable editorial storytelling that elevates brand perception and prestige\"},{\"title\":\"Category Navigation System\",\"description\":\"Breadcrumb navigation, filter bars, sort options, and pagination create intuitive browsing experiences for jewelry collections and product lines\"},{\"title\":\"Product Detail Pages\",\"description\":\"Accordion-based descriptions, review sections, and detailed specifications present jewelry information professionally for confident purchasing decisions\"},{\"title\":\"Brand Story Pages\",\"description\":\"Dedicated about sections for brand story, sustainability commitments, and values communicate luxury positioning that justifies premium pricing\"},{\"title\":\"Shadcn UI Component Library\",\"description\":\"40+ pre-built components including forms, dialogs, cards, and dropdowns accelerate customization without compromising professional design standards\"},{\"title\":\"TypeScript and React Foundation\",\"description\":\"Modern tech stack with Vite build tool enables developers to extend functionality and add backend integrations as business grows\"},{\"title\":\"Tailwind CSS Design System\",\"description\":\"Custom design tokens and semantic color system with dark mode support allow brand customization while maintaining visual consistency\"},{\"title\":\"Store Locator Framework\",\"description\":\"Built-in store locator pages with map integration placeholders enable multi-location retailers to showcase physical presence and drive foot traffic\"},{\"title\":\"Privacy and Legal Pages\",\"description\":\"Pre-built privacy policy and terms of service pages establish trust and meet compliance requirements for e-commerce operations\"},{\"title\":\"Responsive Typography System\",\"description\":\"DM Sans font with fluid type scales ensures exceptional readability and luxury aesthetic across all screen sizes and devices\"}],\"content\":\"$52\",\"relativePath\":\"ecommerce-store-1.md\"}]}]]\n"])</script></body></html>